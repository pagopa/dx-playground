{
  "extends": "@pagopa/typescript-config-node/tsconfig.json",
  "exclude": [
    "dist",
    "**/__tests__/",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "sourceMap": true,
    "inlineSources": true,
    "allowSyntheticDefaultImports": true
  }
}
